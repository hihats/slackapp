{
  "permissions": {
    "allow": [
      "Bash(git pull:*)",
      "WebFetch(domain:docs.cursor.com)",
      "WebFetch(domain:api.slack.com)",
      "WebFetch(domain:docs.slack.dev)",
      "Bash(python *)",
      "Bash(pip install *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Read(*.py)",
      "Read(*.json)",
      "Read(*.md)",
      "Read(*.txt)",
      "Read(outputs/*)",
      "Write(*.py)",
      "Write(outputs/*)",
      "Edit(*.py)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Read(.env*)",
      "Read(*/secrets/**)",
      "Write(.env*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_BUG_COMMAND": "1"
  }
}
